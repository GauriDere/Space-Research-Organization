<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE web-app PUBLIC
    "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<!--
  web.xml — Deployment Descriptor for SRO Web Application
  Assignment: Servlet, JSP, EJB integration configuration
  Configures: Servlet mappings, welcome file, session timeout, error pages
-->
<web-app>

    <display-name>SRO - Space Research Organization</display-name>
    <description>
        ORION Space Research Organization Web Application.
        Demonstrates HTML, CSS, JavaScript, Servlet, JSP, MySQL, EJB, AngularJS, Struts.
    </description>

    <!-- ── Session Configuration ─────────────────────────────────────────── -->
    <session-config>
        <!-- Session timeout: 30 minutes -->
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ── Welcome Files ─────────────────────────────────────────────────── -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ── Servlet: SpaceOperationsServlet (CRUD) ────────────────────────── -->
    <servlet>
        <servlet-name>SpaceOperationsServlet</servlet-name>
        <servlet-class>com.sro.servlet.SpaceOperationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SpaceOperationsServlet</servlet-name>
        <url-pattern>/operations</url-pattern>
    </servlet-mapping>

    <!-- ── Servlet: LoginServlet ─────────────────────────────────────────── -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.sro.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- ── Servlet: RegistrationServlet ─────────────────────────────────── -->
    <servlet>
        <servlet-name>RegistrationServlet</servlet-name>
        <servlet-class>com.sro.servlet.RegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistrationServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- ── Servlet: WelcomeServlet (uses EJB) ────────────────────────────── -->
    <servlet>
        <servlet-name>WelcomeServlet</servlet-name>
        <servlet-class>com.sro.servlet.WelcomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WelcomeServlet</servlet-name>
        <url-pattern>/welcome</url-pattern>
    </servlet-mapping>

    <!-- ── Servlet: LogoutServlet ─────────────────────────────────────────── -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.sro.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- ── Error Pages ────────────────────────────────────────────────────── -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error500.jsp</location>
    </error-page>

</web-app>
